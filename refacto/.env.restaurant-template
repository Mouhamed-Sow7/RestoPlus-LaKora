# ─── RestoPlus — Template Variables d'environnement Render ───────────────
# Copier ce fichier, remplir les valeurs, et les coller dans Render Dashboard
# → Service → Environment → Add Environment Variable

# ─── IDENTITÉ RESTAURANT ──────────────────────────────────────────────────
RESTAURANT_ID=sikki
RESTAURANT_NAME=Restaurant Sikki
RESTAURANT_ADDR=123 Avenue Cheikh Anta Diop, Dakar
RESTAURANT_PHONE=+221 77 XXX XX XX
RESTAURANT_EMAIL=contact@sikki.sn
RESTAURANT_WEB=https://sikki.sn

# ─── LOCALE ───────────────────────────────────────────────────────────────
RESTAURANT_CURRENCY=CFA
RESTAURANT_TZ=Africa/Dakar
RESTAURANT_LOCALE=fr-FR

# ─── PAIEMENT MOBILE ──────────────────────────────────────────────────────
WAVE_PHONE=77XXXXXXX
OM_PHONE=77XXXXXXX
CASH_ENABLED=true
CARD_ENABLED=true
WAVE_ENABLED=true
OM_ENABLED=true

# ─── BRANDING ─────────────────────────────────────────────────────────────
# Couleur principale (hex)
BRAND_COLOR=#1a6b3c
BRAND_COLOR_DARK=#0f4a28
BRAND_COLOR_ACCENT=#4caf80
# URLs des images (hébergées sur CDN ou dossier public)
LOGO_URL=
FAVICON_URL=
BANNER_URL=

# ─── TABLES ───────────────────────────────────────────────────────────────
TABLE_COUNT=8
TABLE_PREFIX=Table
# Zones séparées par virgule
TABLE_ZONES=Salle principale,Terrasse,Salle VIP

# ─── FONCTIONNALITÉS ──────────────────────────────────────────────────────
FEATURE_FUSION=true
FEATURE_STATS=true
FEATURE_HISTORY=true
FEATURE_NOTIFS=true

# ─── BASE DE DONNÉES (propre à chaque restaurant) ─────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/restoplus-sikki?retryWrites=true&w=majority

# ─── AUTH ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGEME_secret_unique_par_restaurant_min32chars
JWT_REFRESH_SECRET=CHANGEME_refresh_secret_unique
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEME_motdepasse_admin
SERVER_USERNAME=serveur
SERVER_PASSWORD=CHANGEME_motdepasse_serveur

# ─── RENDER ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
